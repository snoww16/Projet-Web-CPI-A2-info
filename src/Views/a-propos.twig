{% extends 'layout.twig' %}
{% block title %}À propos - CESI Ton Stage{% endblock %}

{% block content %}
<div class="container" style="padding-top: 40px; padding-bottom: 60px;">
    
    <section style="text-align: center; margin-bottom: 60px;">
        <h1 style="color: #38bdf8; font-size: 3rem; margin-bottom: 20px;">Notre Mission 🚀</h1>
        <p style="font-size: 1.2rem; color: #cbd5e1; max-width: 800px; margin: 0 auto; line-height: 1.6;">
            Faciliter la rencontre entre les talents de demain et les entreprises innovantes. <strong>CESI Ton Stage</strong> est la plateforme de référence pour les étudiants à la recherche d'une expérience professionnelle formatrice.
        </p>
    </section>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 60px;">
        
        <div class="card" style="padding: 40px; text-align: center; background: rgba(255,255,255,0.02); border-top: 4px solid #38bdf8;">
            <div style="font-size: 3rem; margin-bottom: 20px;">🎓</div>
            <h3 style="margin-bottom: 15px;">Pour les Étudiants</h3>
            <p style="color: #94a3b8; line-height: 1.5;">Un accès centralisé à des centaines d'offres qualifiées, un suivi des candidatures simplifié et la possibilité de mettre en avant vos compétences de manière professionnelle.</p>
        </div>

        <div class="card" style="padding: 40px; text-align: center; background: rgba(255,255,255,0.02); border-top: 4px solid #10b981;">
            <div style="font-size: 3rem; margin-bottom: 20px;">🏢</div>
            <h3 style="margin-bottom: 15px;">Pour les Entreprises</h3>
            <p style="color: #94a3b8; line-height: 1.5;">Une visibilité directe auprès des profils ingénieurs et techniciens du CESI. Déposez vos offres en quelques clics et trouvez le stagiaire ou l'alternant idéal.</p>
        </div>

        <div class="card" style="padding: 40px; text-align: center; background: rgba(255,255,255,0.02); border-top: 4px solid #8b5cf6;">
            <div style="font-size: 3rem; margin-bottom: 20px;">👨‍🏫</div>
            <h3 style="margin-bottom: 15px;">Pour les Pilotes</h3>
            <p style="color: #94a3b8; line-height: 1.5;">Un outil d'administration puissant pour suivre l'évolution des étudiants, valider les entreprises partenaires et garantir la qualité pédagogique des stages.</p>
        </div>
        
    </div>

    <section class="card" style="padding: 50px; text-align: center; background: linear-gradient(135deg, rgba(15,23,42,1) 0%, rgba(56,189,248,0.1) 100%);">
        <h2 style="margin-bottom: 40px;">CESI Ton Stage en chiffres</h2>
        <div style="display: flex; justify-content: space-around; flex-wrap: wrap; gap: 20px;">
            <div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #38bdf8;">+500</div>
                <div style="color: #cbd5e1;">Offres de stage</div>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #10b981;">+120</div>
                <div style="color: #cbd5e1;">Entreprises partenaires</div>
            </div>
            <div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #8b5cf6;">98%</div>
                <div style="color: #cbd5e1;">Taux de placement</div>
            </div>
        </div>
    </section>

</div>
{% endblock %}