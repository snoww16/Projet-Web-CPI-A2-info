{% extends 'layout.twig' %}
{% block title %}{{ is_edit ? 'Modifier' : 'Créer' }} un(e) {{ type|slice(0, -1) }} - CESI Ton Stage{% endblock %}

{% block content %}
<section class="container" style="max-width: 850px; margin-top: 40px;">
    <div class="card" style="padding: 30px;">
        <h2 style="margin-bottom: 20px; color: #38bdf8;">
            {{ is_edit ? '✏️ Modifier' : '✨ Créer' }} {{ type == 'entreprises' ? 'une' : 'un' }} {{ type|slice(0, -1) }}
        </h2>
        
        <form action="" method="POST" class="formulaire">
            
            {# ================= UTILISATEURS ================= #}
            {% if type in ['etudiants', 'pilotes'] %}
                <div class="ligne-champ">
                    <label>Nom</label>
                    <input type="text" name="nom" value="{{ donnees.nom|default('') }}" required>
                </div>
                <div class="ligne-champ">
                    <label>Prénom</label>
                    <input type="text" name="prenom" value="{{ donnees.prenom|default('') }}" required>
                </div>
                <div class="ligne-champ">
                    <label>Email</label>
                    <input type="email" name="email" value="{{ donnees.email|default('') }}" required>
                </div>
                <div class="ligne-champ">
                    <label>Mot de passe {{ is_edit ? '(Laisser vide pour ne pas changer)' : '' }}</label>
                    <input type="password" name="password" {{ is_edit ? '' : 'required' }}>
                </div>

            {# ================= ENTREPRISES ================= #}
            {% elseif type == 'entreprises' %}
                <div class="ligne-champ">
                    <label>Nom de l'entreprise</label>
                    <input type="text" name="nom" value="{{ donnees.nom|default('') }}" required>
                </div>
                <div class="ligne-champ">
                    <label>Description</label>
                    <textarea name="description" rows="4" required>{{ donnees.description|default('') }}</textarea>
                </div>
                <div class="ligne-champ" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label>Email de contact</label>
                        <input type="email" name="email" value="{{ donnees.email_contact|default('') }}" required>
                    </div>
                    <div>
                        <label>Téléphone</label>
                        <input type="text" name="telephone" value="{{ donnees.telephone|default('') }}" required>
                    </div>
                </div>

            {# ================= OFFRES DE STAGE ================= #}
            {% elseif type == 'offres' %}
                <div class="ligne-champ">
                    <label>Titre de l'offre</label>
                    <input type="text" name="titre" value="{{ donnees.titre|default('') }}" placeholder="Ex: Développeur Web Full-Stack" required>
                </div>
                
                <div class="ligne-champ" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label>Entreprise</label>
                        <select name="entreprise" required>
                            <option value="">Sélectionner une entreprise</option>
                            {% for ent in entreprises %}
                                <option value="{{ ent.id_entreprise }}" {% if donnees.id_entreprise|default('') == ent.id_entreprise %}selected{% endif %}>{{ ent.nom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label>Ville</label>
                        <input type="text" name="ville" value="{{ donnees.ville|default('') }}" placeholder="Ex: Paris, Lyon..." required>
                    </div>
                </div>

                <div class="ligne-champ" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div>
                        <label>Domaine</label>
                        <select name="domaine" required>
                            <option value="">Sélectionner un domaine</option>
                            {% for dom in domaines %}
                                <option value="{{ dom }}" {% if donnees.domaine|default('') == dom %}selected{% endif %}>{{ dom }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div>
                        <label>Niveau Requis</label>
                        <select name="niveau_requis" required>
                            <option value="">Sélectionner un niveau</option>
                            {% for niv in niveaux %}
                                <option value="{{ niv }}" {% if donnees.niveau_requis|default('') == niv %}selected{% endif %}>{{ niv }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="ligne-champ" style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 15px;">
                    <div>
                        <label>Type de Contrat</label>
                        <select name="type_contrat" required>
                            <option value="Stage" {% if donnees.type_contrat|default('') == 'Stage' %}selected{% endif %}>Stage</option>
                            <option value="Alternance" {% if donnees.type_contrat|default('') == 'Alternance' %}selected{% endif %}>Alternance</option>
                        </select>
                    </div>
                    <div>
                        <label>Durée (mois)</label>
                        <input type="number" name="duree" value="{{ donnees.duree|default('') }}" min="1" required>
                    </div>
                    <div>
                        <label>Rémunération (€)</label>
                        <input type="number" name="remuneration" value="{{ donnees.remuneration|default('') }}" step="1" placeholder="Ex: 800">
                    </div>
                    <div>
                        <label>Date de début</label>
                        <input type="date" name="date_debut" value="{{ donnees.date_debut|default('') }}" required>
                    </div>
                </div>

                <div class="ligne-champ">
                    <label>Description détaillée de l'offre</label>
                    <textarea name="description" rows="6" placeholder="Missions, profil recherché..." required>{{ donnees.offre_desc|default(donnees.description|default('')) }}</textarea>
                </div>
            {% endif %}

            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button type="submit" class="btn-appliquer" style="flex: 1; padding: 12px; font-size: 1.1rem;">
                    {{ is_edit ? '💾 Enregistrer les modifications' : '✅ Créer ' ~ (type == 'entreprises' ? 'l\'' : 'le ') ~ type|slice(0, -1) }}
                </button>
                <a href="/admin/{{ type }}" class="btn-reset" style="padding: 12px 25px;">Annuler</a>
            </div>
        </form>
    </div>
</section>
{% endblock %}