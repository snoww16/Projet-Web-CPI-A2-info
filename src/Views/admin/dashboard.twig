{% extends 'layout.twig' %}
{% block title %}Espace Administration{% endblock %}

{% block content %}
<div class="entete-page">
    <h2>Espace Administration</h2>
    <p class="hint">Gérez les différentes entités du système selon vos droits.</p>
</div>

<div class="container">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; padding: 20px 0;">
        
        {% if session.role == 1 %}
        <a href="/admin/pilotes" class="card" style="text-align: center; text-decoration: none; display: block;">
            <h3 style="color: #38bdf8;">Comptes Pilotes</h3>
            <p>Créer, modifier, supprimer un pilote.</p>
        </a>
        {% endif %}

        <a href="/admin/etudiants" class="card" style="text-align: center; text-decoration: none; display: block;">
            <h3 style="color: #38bdf8;">Comptes Étudiants</h3>
            <p>Créer, modifier, supprimer un étudiant.</p>
        </a>

        <a href="/admin/entreprises" class="card" style="text-align: center; text-decoration: none; display: block;">
            <h3 style="color: #38bdf8;">Entreprises</h3>
            <p>Créer, modifier, supprimer une entreprise.</p>
        </a>

        <a href="/admin/offres" class="card" style="text-align: center; text-decoration: none; display: block;">
            <h3 style="color: #38bdf8;">Offres de stage</h3>
            <p>Créer, modifier, supprimer une offre.</p>
        </a>
    </div>
</div>
{% endblock %}