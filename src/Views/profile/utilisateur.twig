{% extends 'layout.twig' %}
{% block title %}Profil de {{ user_profile.prenom }} {{ user_profile.nom }} - CESI Ton Stage{% endblock %}

{% block content %}
<main class="container">
    <section class="entete-page" style="text-align: center; padding: 40px 0; margin-bottom: 10px;">
        <h2>Espace Personnel</h2>
        <p class="hint">Profil de {{ user_profile.prenom }} {{ user_profile.nom }}</p>
    </section>

    <section class="profile-grid" style="display: grid; grid-template-columns: minmax(240px, 300px) 1fr; gap: 18px; align-items: stretch; margin-bottom: 20px;">
        <div class="left-panel" style="display: flex; flex-direction: column; gap: 16px;">
            <div class="card profile-card profile-personal" style="text-align: center;">
                <div style="width: 120px; height: 120px; margin: 0 auto 15px; border-radius: 50%; overflow: hidden; border: 3px solid #38bdf8;">
                    {% if user_profile.photo_path %}
                        <img src="{{ user_profile.photo_path }}" alt="Avatar" style="width: 100%; height: 100%; object-fit: cover;">
                    {% else %}
                        <img src="https://ui-avatars.com/api/?name={{ user_profile.nom ~ ' ' ~ user_profile.prenom }}&background=38bdf8&color=0F172A&size=150" alt="Avatar" style="width: 100%; height: 100%;">
                    {% endif %}
                </div>
                <h3>{{ user_profile.prenom }} {{ user_profile.nom }}</h3>
                <p style="color: #94a3b8; font-size: 0.9rem; margin-bottom: 15px;">
                    {% if user_profile.id_role == 1 %}Administrateur{% elseif user_profile.id_role == 2 %}Pilote CESI{% else %}Étudiant{% endif %}
                </p>

                {% if is_owner %}
                    <form action="/profil/avatar" method="POST" enctype="multipart/form-data" id="avatar-form">
                        <label for="avatar-input" class="btn-simple primary" style="cursor: pointer; padding: 8px 15px; font-size: 0.9rem;">Modifier la photo</label>
                        <input type="file" name="avatar" id="avatar-input" style="display:none;" onchange="document.getElementById('avatar-form').submit();" accept="image/*">
                    </form>
                {% elseif session.role in [1, 2] %}
                    <a href="/admin/{{ user_profile.id_role == 2 ? 'pilotes' : 'etudiants' }}/modifier/{{ user_profile.id_user }}" class="btn-simple">Modifier ce profil</a>
                {% endif %}
            </div>

            <div class="card profile-card profile-maininfo">
                <h4 style="margin-bottom: 15px; color: #38bdf8;">Informations</h4>
                <ul style="list-style: none; padding: 0; color: #cbd5e1; display: flex; flex-direction: column; gap: 8px;">
                    <li><strong>📧 Email :</strong> {{ user_profile.email }}</li>
                    {% if user_profile.id_role == 3 %}
                        <li>
                            <strong>📌 Statut :</strong> 
                            {% set colorStatut = user_profile.statut_recherche == 'Stage trouvé' ? '#10b981' : (user_profile.statut_recherche == 'En entretien' ? '#f59e0b' : '#38bdf8') %}
                            <span style="color: {{ colorStatut }}; font-weight: bold;">{{ user_profile.statut_recherche|default('En recherche') }}</span>
                        </li>
                        {% if user_profile.pilote_nom %}
                            <li><strong>👨‍🏫 Pilote :</strong> {{ user_profile.pilote_prenom }} {{ user_profile.pilote_nom }}</li>
                        {% endif %}
                    {% endif %}
                </ul>
            </div>
        </div>

        <div class="right-panel" style="display: flex; flex-direction: column;">
            <div class="card right-card" style="flex: 1; padding: 0; overflow: hidden; display: flex; flex-direction: column;">
                
                <div class="right-tabs" style="display: flex; border-bottom: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.2);">
                    {% if user_profile.id_role == 3 %}
                        {% if can_view_applications %}<button class="tab-btn active" data-target="candidatures-tab" style="flex: 1; padding: 15px; background: none; border: none; color: white; cursor: pointer; border-bottom: 3px solid #38bdf8;">Candidatures</button>{% endif %}
                        {% if is_owner %}<button class="tab-btn {% if not can_view_applications %}active{% endif %}" data-target="wishlist-tab" style="flex: 1; padding: 15px; background: none; border: none; color: white; cursor: pointer;">Wishlist</button>{% endif %}
                    {% elseif user_profile.id_role == 2 %}
                        <button class="tab-btn active" data-target="etudiants-tab" style="flex: 1; padding: 15px; background: none; border: none; color: white; cursor: pointer; border-bottom: 3px solid #38bdf8;">Mes Étudiants</button>
                    {% elseif user_profile.id_role == 1 %}
                        <button class="tab-btn active" data-target="admin-tab" style="flex: 1; padding: 15px; background: none; border: none; color: white; cursor: pointer; border-bottom: 3px solid #38bdf8;">Panneau d'Administration</button>
                    {% endif %}
                </div>

                <div style="padding: 25px;">
                    {% if user_profile.id_role == 3 %}
                        
                        {% if can_view_applications %}
                        <div class="tab-content active" id="candidatures-tab">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                                <h3 style="margin: 0;">Dernières candidatures</h3>
                                {% if is_owner %}<a href="/mes-candidatures" class="btn-simple">Tout afficher</a>{% endif %}
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 15px;">
                                {% for offre in candidatures %}
                                    {% include 'offers/_card.twig' %}
                                {% else %}
                                    <p style="color: #94a3b8; text-align: center; padding: 20px;">Aucune candidature récente.</p>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}

                        {% if is_owner %}
                        <div class="tab-content {% if not can_view_applications %}active{% endif %}" id="wishlist-tab" style="display: none;">
                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                                <h3 style="margin: 0;">Wishlist ❤️</h3>
                                <a href="/mes-favoris" class="btn-simple">Tout afficher</a>
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 15px;">
                                {% for offre in wishlist_offres %}
                                    {% include 'offers/_card.twig' %}
                                {% else %}
                                    <p style="color: #94a3b8; text-align: center; padding: 20px;">Wishlist vide.</p>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}

                    {% elseif user_profile.id_role == 2 %}
                        <div class="tab-content active" id="etudiants-tab">
                            <h3 style="margin-bottom: 20px;">Étudiants assignés</h3>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                {% for etu in mes_etudiants %}
                                    <a href="/profil/{{ etu.id_user }}" class="card" style="padding: 15px; display: flex; align-items: center; gap: 15px;">
                                        <img src="{{ etu.photo_path|default('https://ui-avatars.com/api/?name=' ~ etu.nom|url_encode ~ '&background=38bdf8&color=0F172A') }}" alt="Avatar" style="width: 40px; height: 40px; border-radius: 50%;">
                                        <div>
                                            <div style="font-weight: bold; color: white;">{{ etu.prenom }} {{ etu.nom }}</div>
                                            <div style="font-size: 0.8rem; color: #94a3b8;">{{ etu.statut_recherche|default('En recherche') }}</div>
                                        </div>
                                    </a>
                                {% else %}
                                    <p style="color: #94a3b8; grid-column: span 2;">Aucun étudiant assigné.</p>
                                {% endfor %}
                            </div>
                        </div>

                    {% elseif user_profile.id_role == 1 %}
                        <div class="tab-content active" id="admin-tab">
                            <h3 style="margin-bottom: 20px;">Raccourcis rapides</h3>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                <a href="/admin/offres" class="card" style="text-align: center; padding: 25px; text-decoration: none; transition: 0.3s;">
                                    <div style="font-size: 2.5rem; margin-bottom: 10px;">💼</div>
                                    <h4 style="color: white; margin: 0;">Gérer les offres</h4>
                                </a>
                                <a href="/admin/etudiants" class="card" style="text-align: center; padding: 25px; text-decoration: none; transition: 0.3s;">
                                    <div style="font-size: 2.5rem; margin-bottom: 10px;">🎓</div>
                                    <h4 style="color: white; margin: 0;">Gérer les étudiants</h4>
                                </a>
                                <a href="/admin/entreprises" class="card" style="text-align: center; padding: 25px; text-decoration: none; transition: 0.3s;">
                                    <div style="font-size: 2.5rem; margin-bottom: 10px;">🏢</div>
                                    <h4 style="color: white; margin: 0;">Gérer les entreprises</h4>
                                </a>
                                <a href="/admin/pilotes" class="card" style="text-align: center; padding: 25px; text-decoration: none; transition: 0.3s;">
                                    <div style="font-size: 2.5rem; margin-bottom: 10px;">👨‍🏫</div>
                                    <h4 style="color: white; margin: 0;">Gérer les pilotes</h4>
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
</main>

<script>
    // Script JS pour gérer les onglets
    const tabButtons = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            tabButtons.forEach(b => {
                b.classList.remove('active');
                b.style.borderBottom = 'none';
            });
            btn.classList.add('active');
            btn.style.borderBottom = '3px solid #38bdf8';

            const targetId = btn.dataset.target;
            tabContents.forEach(content => {
                if(content.id === targetId) {
                    content.style.display = 'block';
                } else {
                    content.style.display = 'none';
                }
            });
        });
    });
</script>
{% endblock %}