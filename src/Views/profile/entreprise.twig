{% extends 'layout.twig' %}
{% block title %}{{ entreprise.nom }} - Profil Entreprise{% endblock %}

{% block content %}
<main class="container">
    <section class="entete-page" style="text-align: center; padding: 40px 0; margin-bottom: 10px;">
        <h2>Profil Entreprise</h2>
    </section>

    <section class="profile-grid" style="display: grid; grid-template-columns: minmax(240px, 300px) 1fr; gap: 18px; align-items: stretch; margin-bottom: 20px;">
        
        <div class="left-panel" style="display: flex; flex-direction: column; gap: 16px;">
            <div class="card profile-card profile-personal" style="text-align: center;">
                <div style="width: 120px; height: 120px; margin: 0 auto 15px; border-radius: 15px; overflow: hidden; background: white; padding: 10px;">
                    <img src="{{ entreprise.logo_path|default('https://ui-avatars.com/api/?name=' ~ entreprise.nom|url_encode ~ '&background=fff&color=0F172A') }}" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;">
                </div>
                <h3>{{ entreprise.nom }}</h3>

                {% if entreprise.nb_avis > 0 %}
                    <div style="color: #facc15; font-size: 1.2rem; margin-top: 10px; font-weight: bold;">
                        ⭐ {{ entreprise.moyenne_avis }} / 5
                    </div>
                    <div style="color: #64748b; font-size: 0.85rem;">({{ entreprise.nb_avis }} avis)</div>
                {% endif %}

                {% if session.role in [1, 2] %}
                    <a href="/admin/entreprises/modifier/{{ entreprise.id_entreprise }}" class="btn-simple primary" style="margin-top: 15px; display: inline-block;">Modifier le profil</a>
                {% endif %}
            </div>

            <div class="card profile-card profile-maininfo">
                <h4 style="margin-bottom: 15px; color: #38bdf8;">Coordonnées & Info</h4>
                <ul style="list-style: none; padding: 0; color: #cbd5e1; display: flex; flex-direction: column; gap: 8px;">
                    <li><strong>📧 Email :</strong> {{ entreprise.email_contact|default('Non renseigné') }}</li>
                    <li><strong>📞 Téléphone :</strong> {{ entreprise.telephone|default('Non renseigné') }}</li>
                </ul>
                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);">
                    <h4 style="margin-bottom: 5px; color: #38bdf8; font-size: 0.9rem;">Description</h4>
                    <p style="color: #94a3b8; font-size: 0.9rem;">{{ entreprise.description }}</p>
                </div>
            </div>
        </div>

        <div class="right-panel" style="display: flex; flex-direction: column;">
            
            <div style="display: flex; gap: 10px; margin-bottom: 15px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                <button onclick="switchTab('offres')" id="btn-tab-offres" class="btn-simple primary" style="font-weight: bold;">Offres proposées</button>
                <button onclick="switchTab('avis')" id="btn-tab-avis" class="btn-simple" style="font-weight: bold;">Avis ({{ entreprise.nb_avis }})</button>
            </div>

            <div id="tab-offres" class="card right-card" style="flex: 1; padding: 25px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0;">Offres proposées</h3>
                    <a href="/offres?q={{ entreprise.nom }}" class="btn-simple">Voir toutes les offres</a>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    {% for offre in offres %}
                        {% include 'offers/_card.twig' %}
                    {% else %}
                        <p style="color: #94a3b8; text-align: center; padding: 20px;">Cette entreprise n'a publié aucune offre pour le moment.</p>
                    {% endfor %}
                </div>
            </div>

            <div id="tab-avis" class="card right-card" style="flex: 1; padding: 25px; display: none;">
                <h3 style="margin-top: 0; margin-bottom: 20px; color: #facc15;">Avis sur l'entreprise</h3>

                {% if session.role in [1, 2] %}
                <div style="background: rgba(250, 204, 21, 0.05); padding: 20px; border-radius: 12px; border: 1px solid rgba(250, 204, 21, 0.2); margin-bottom: 25px;">
                    <h4 style="color: #facc15; margin-bottom: 15px; margin-top: 0;">⭐ Laisser une évaluation</h4>
                    <form action="/entreprise/evaluer" method="POST" class="formulaire">
                        <input type="hidden" name="id_entreprise" value="{{ entreprise.id_entreprise }}">
                        <div class="ligne-champ">
                            <label>Note sur 5 :</label>
                            <select name="note" required style="width: auto;">
                                <option value="5">⭐⭐⭐⭐⭐ (Excellent)</option>
                                <option value="4">⭐⭐⭐⭐ (Très bien)</option>
                                <option value="3">⭐⭐⭐ (Bien)</option>
                                <option value="2">⭐⭐ (Moyen)</option>
                                <option value="1">⭐ (À éviter)</option>
                            </select>
                        </div>
                        <div class="ligne-champ">
                            <label>Commentaire (Optionnel) :</label>
                            <textarea name="commentaire" rows="3" placeholder="Votre avis sur cette entreprise..."></textarea>
                        </div>
                        <button type="submit" class="btn-appliquer" style="background: #facc15; color: #000; margin-top: 10px;">Publier l'avis</button>
                    </form>
                </div>
                {% endif %}

                <div style="display: flex; flex-direction: column; gap: 15px;">
                    {% for eval in evaluations %}
                        <div style="background: rgba(255,255,255,0.03); padding: 15px; border-radius: 12px; border-left: 3px solid #facc15;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                                <span style="color: #facc15; letter-spacing: 2px;">
                                    {% for i in 1..5 %}{{ i <= eval.note ? '★' : '☆' }}{% endfor %}
                                </span>
                                <span style="color: #64748b; font-size: 0.8rem;">Le {{ eval.date_eval }}</span>
                            </div>
                            <div style="font-size: 0.85rem; color: #94a3b8; margin-bottom: 8px;">Par {{ eval.prenom }} {{ eval.nom|first }}. ({{ eval.id_role == 1 ? 'Admin' : 'Pilote' }})</div>
                            {% if eval.commentaire %}
                                <p style="color: #e9eef7; font-size: 0.95rem; margin: 0; font-style: italic;">"{{ eval.commentaire }}"</p>
                            {% endif %}
                        </div>
                    {% else %}
                        <p style="color: #94a3b8; font-style: italic; text-align: center; padding: 10px;">Aucune évaluation pour le moment.</p>
                    {% endfor %}
                </div>
            </div>

        </div>
    </section>
</main>

<script>
function switchTab(tabName) {
    // Cacher tous les onglets
    document.getElementById('tab-offres').style.display = 'none';
    document.getElementById('tab-avis').style.display = 'none';
    
    // Réinitialiser les boutons
    document.getElementById('btn-tab-offres').className = 'btn-simple';
    document.getElementById('btn-tab-avis').className = 'btn-simple';
    
    // Afficher l'onglet actif et le bouton en primary
    document.getElementById('tab-' + tabName).style.display = 'block';
    document.getElementById('btn-tab-' + tabName).className = 'btn-simple primary';
}
</script>
{% endblock %}