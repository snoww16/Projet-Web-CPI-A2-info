{% extends 'layout.twig' %}
{% block title %}{{ entreprise.nom }} - Profil Entreprise{% endblock %}

{% block content %}
<main class="container">
    <section class="entete-page" style="text-align: center; padding: 40px 0; margin-bottom: 10px;">
        <h2>Profil Entreprise</h2>
    </section>

    <section class="profile-grid" style="display: grid; grid-template-columns: minmax(240px, 300px) 1fr; gap: 18px; align-items: stretch; margin-bottom: 20px;">
        <div class="left-panel" style="display: flex; flex-direction: column; gap: 16px;">
            <div class="card profile-card profile-personal" style="text-align: center;">
                <div style="width: 120px; height: 120px; margin: 0 auto 15px; border-radius: 15px; overflow: hidden; background: white; padding: 10px;">
                    <img src="{{ entreprise.logo_path|default('https://ui-avatars.com/api/?name=' ~ entreprise.nom|url_encode ~ '&background=fff&color=0F172A') }}" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;">
                </div>
                <h3>{{ entreprise.nom }}</h3>

                {% if session.role in [1, 2] %}
                    <a href="/admin/entreprises/modifier/{{ entreprise.id_entreprise }}" class="btn-simple primary" style="margin-top: 15px; display: inline-block;">Modifier le profil</a>
                {% endif %}
            </div>

            <div class="card profile-card profile-maininfo">
                <h4 style="margin-bottom: 15px; color: #38bdf8;">Coordonnées & Info</h4>
                <ul style="list-style: none; padding: 0; color: #cbd5e1; display: flex; flex-direction: column; gap: 8px;">
                    <li><strong>📧 Email :</strong> {{ entreprise.email_contact|default('Non renseigné') }}</li>
                    <li><strong>📞 Téléphone :</strong> {{ entreprise.telephone|default('Non renseigné') }}</li>
                </ul>
                <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid rgba(255,255,255,0.1);">
                    <h4 style="margin-bottom: 5px; color: #38bdf8; font-size: 0.9rem;">Description</h4>
                    <p style="color: #94a3b8; font-size: 0.9rem;">{{ entreprise.description }}</p>
                </div>
            </div>
        </div>

        <div class="right-panel" style="display: flex; flex-direction: column;">
            <div class="card right-card" style="flex: 1; padding: 25px;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px;">
                    <h3 style="margin: 0;">Offres proposées</h3>
                    <a href="/offres?q={{ entreprise.nom }}" class="btn-simple">Voir toutes les offres</a>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 15px;">
                    {% for offre in offres %}
                        {% include 'offers/_card.twig' %}
                    {% else %}
                        <p style="color: #94a3b8; text-align: center; padding: 20px;">Cette entreprise n'a publié aucune offre pour le moment.</p>
                    {% endfor %}
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}