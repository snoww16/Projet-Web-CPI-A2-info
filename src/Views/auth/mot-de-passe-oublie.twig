{% extends 'layout.twig' %}
{% block title %}Mot de passe oublié{% endblock %}

{% block content %}
<div class="entete-page">
    <h2>Mot de passe oublié</h2>
    <p class="hint">Saisissez votre e-mail pour recevoir un lien de réinitialisation.</p>
</div>

<div class="container" style="max-width: 450px; margin-top: 20px;">
    <div class="cardCVLM">
        {% if message %}
            <div style="background: rgba(16, 185, 129, 0.2); color: #a7f3d0; padding: 15px; border-radius: 10px; margin-bottom: 20px; text-align: center;">
                {{ message }}
            </div>
            <a href="/login" class="btn-simple" style="display: block; text-align: center;">Retour à la connexion</a>
        {% else %}
            <form action="/mot-de-passe-oublie" method="POST" class="formulaire">
                <div class="ligne-champ">
                    <label for="email">Votre adresse e-mail</label>
                    <input type="email" name="email" id="email" required placeholder="votre.email@exemple.com">
                </div>
                <button type="submit" class="btn-simple primary" style="width: 100%; margin-top: 15px;">Envoyer le lien</button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}