{% extends 'layout.twig' %}
{% block title %}Première connexion - Sécurité{% endblock %}

{% block content %}
<main class="container" style="display: flex; justify-content: center; align-items: center; min-height: 70vh;">
    <div class="card" style="width: 100%; max-width: 500px; text-align: center;">
        <h2 style="margin-bottom: 10px; color: #38bdf8;">Sécurisez votre compte</h2>
        <p style="color: #94a3b8; margin-bottom: 25px; font-size: 0.9rem;">
            Ceci est votre première connexion. Pour des raisons de sécurité, vous devez définir un mot de passe personnel avant d'accéder à la plateforme.
        </p>

        {% if erreur %}
            <div style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid rgba(239, 68, 68, 0.4);">
                {{ erreur }}
            </div>
        {% endif %}

        <form action="/premiere-connexion" method="POST" style="display: flex; flex-direction: column; gap: 15px; text-align: left;">
            
            <div class="ligne-champ">
                <label for="new_password">Nouveau mot de passe</label>
                <input type="password" name="new_password" id="new_password" required minlength="8" placeholder="8 caractères minimum">
            </div>

            <div class="ligne-champ">
                <label for="confirm_password">Confirmez le mot de passe</label>
                <input type="password" name="confirm_password" id="confirm_password" required placeholder="Retapez le mot de passe">
            </div>

            <button type="submit" class="btn-simple primary" style="width: 100%; margin-top: 10px; padding: 14px;">
                Valider et accéder au site
            </button>
        </form>
    </div>
</main>
{% endblock %}