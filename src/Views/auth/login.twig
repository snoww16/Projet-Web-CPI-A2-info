{% extends 'layout.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
<div class="entete-page">
    <h2>Connexion</h2>
    <p class="hint">Veuillez vous identifier pour accéder à votre espace.</p>
</div>

<div class="container" style="max-width: 450px; margin-top: 20px;">
    <div class="cardCVLM">
        
        {% if error %}
        <div style="background-color: rgba(255, 77, 79, 0.1); color: #ff4d4f; border: 1px solid #ff4d4f; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold;">
            ⚠️ {{ error }}
        </div>
        {% endif %}

        <form action="/login" method="POST">
            <div class="ligne-champ">
                <label for="email">Adresse e-mail</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <div class="ligne-champ">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" required>
            </div>

            <button type="submit" class="btn-appliquer" style="width: 100%; margin-top: 10px;">Se connecter</button>
        </form>
    </div>
</div>
{% endblock %}