{% extends 'layout.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
<div class="entete-page">
    <h1>Connexion</h1>
    <p class="hint">Veuillez vous identifier pour accéder à votre espace.</p>
</div>

<div class="container" style="max-width: 450px; margin: 40px auto;">
    <div class="cardCVLM" style="padding: 30px;">
        
        {% if error %}
        <div style="background-color: rgba(255, 77, 79, 0.1); color: #ff4d4f; border: 1px solid #ff4d4f; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
            ⚠️ {{ error }}
        </div>
        {% endif %}

        <form action="/login" method="POST">
            <div class="ligne-champ" style="margin-bottom: 20px;">
                <label for="email">Adresse e-mail</label>
                <input type="email" id="email" name="email" required placeholder="votre@email.fr">
            </div>
            
            <div class="ligne-champ" style="margin-bottom: 10px;">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" required placeholder="••••••••">
            </div>

            <div style="text-align: right; margin-bottom: 20px;">
                <a href="/forgot-password" style="color: #00b4d8; font-size: 0.9em; text-decoration: none;">Mot de passe oublié ?</a>
            </div>

            <button type="submit" class="btn-appliquer" style="width: 100%;">Se connecter</button>
        </form>
    </div>
</div>
{% endblock %}