{% extends 'layout.twig' %}

{% block title %}Connexion - CESI Ton Stage{% endblock %}

{% block content %}
<section class="entete-page" style="text-align: center; margin-top: 40px;">
    <div class="container">
        <h2>Connexion</h2>
        <p>Veuillez vous identifier pour accéder à votre espace.</p>
    </div>
</section>

<section class="zone-principale">
    <div class="container" style="max-width: 500px; margin: 0 auto;">
        <div class="card">
            <form action="/login-submit" method="post" class="formulaire">
                <div class="ligne-champ">
                    <label for="email">Adresse e-mail</label>
                    <input id="email" name="email" type="email" placeholder="ex : prenom.nom@viacesi.fr" required />
                </div>

                <div class="ligne-champ">
                    <label for="mot_de_passe">Mot de passe</label>
                    <input id="mot_de_passe" name="mot_de_passe" type="password" placeholder="Votre mot de passe" required />
                </div>

                <div class="actions-formulaire" style="margin-top: 25px; display: flex; justify-content: space-between; align-items: center;">
                    <button class="btn-simple primary" type="submit">Se connecter</button>
                    <a class="link" href="#" style="font-size: 0.9rem;">Mot de passe oublié ?</a>
                </div>
            </form>
        </div>
    </div>
</section>
{% endblock %}