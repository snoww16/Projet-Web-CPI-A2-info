{% extends 'layout.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
<div class="entete-page">
    <h2>Connexion</h2>
    <p class="hint">Veuillez vous identifier pour accéder à votre espace.</p>
</div>

<div class="container" style="max-width: 450px; margin-top: 20px;">
    <div class="cardCVLM">
        
        {# --- AFFICHAGE DE L'ERREUR --- #}
        {% if erreur %}
            <div style="background: rgba(239, 68, 68, 0.2); color: #fca5a5; padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid rgba(239, 68, 68, 0.4); text-align: center;">
                {{ erreur }}
            </div>
        {% endif %}

        <form action="/login" method="POST" class="formulaire">
            <div class="ligne-champ">
                <label for="email">Adresse Email</label>
                <input type="email" name="email" id="email" value="{{ email }}" required placeholder="prenom.nom@viacesi.fr">
            </div>

            <div class="ligne-champ">
                <label for="mot_de_passe">Mot de passe</label>
                <input type="password" name="mot_de_passe" id="mot_de_passe" required placeholder="Votre mot de passe">
            </div>

            <button type="submit" class="btn-simple primary" style="margin-top: 15px;">Se connecter</button>
        </form>
    </div>
</div>
{% endblock %}