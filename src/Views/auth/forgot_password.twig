{% extends 'layout.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block content %}
<div class="entete-page">
    <h1>Récupération</h1>
    <p class="hint">Entrez votre email pour recevoir un lien.</p>
</div>

<div class="container" style="max-width: 450px; margin: 40px auto;">
    <div class="cardCVLM" style="padding: 30px;">
        
        {% if success %}
        <div style="background-color: rgba(82, 196, 26, 0.1); color: #52c41a; border: 1px solid #52c41a; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center;">
            {{ success }}
        </div>
        {% endif %}

        <form action="/forgot-password" method="POST">
            <div class="ligne-champ" style="margin-bottom: 25px;">
                <label for="email">Votre adresse e-mail</label>
                <input type="email" id="email" name="email" required placeholder="etudiant@viacesi.fr">
            </div>

            <button type="submit" class="btn-appliquer" style="width: 100%;">Envoyer le lien</button>
        </form>
        
        <div style="text-align: center; margin-top: 20px;">
            <a href="/login" style="color: #ccc; font-size: 0.9em; text-decoration: none;">Retour à la connexion</a>
        </div>
    </div>
</div>
{% endblock %}