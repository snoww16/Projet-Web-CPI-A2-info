{% extends 'layout.twig' %}
{% block title %}Contact - CESI Ton Stage{% endblock %}

{% block content %}
<div class="container" style="max-width: 900px; padding: 80px 20px;">
    <div class="card" style="padding: 60px; text-align: center; border: 2px solid #38bdf8;">
        <div style="font-size: 5rem; margin-bottom: 20px;">📩</div>
        <h1 style="color: #fff; font-size: 2.8rem; margin-bottom: 20px;">Besoin d'aide ?</h1>
        <p style="color: #94a3b8; font-size: 1.3rem; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
            Une question sur une offre ou un problème technique avec votre CV ? Notre équipe de support est là pour vous accompagner.
        </p>
        
        <div style="background: linear-gradient(135deg, rgba(56,189,248,0.1) 0%, rgba(56,189,248,0.02) 100%); padding: 40px; border-radius: 20px; border: 1px dashed #38bdf8; display: inline-block; min-width: 350px;">
            <p style="margin: 0; color: #38bdf8; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; font-weight: bold;">Contactez-nous par email</p>
            <p style="margin: 10px 0; color: #fff; font-size: 1.8rem; font-weight: bold;">support@cesi.local</p>
            <p style="margin: 0; color: #94a3b8; font-size: 1rem;">Réponse garantie sous 48h</p>
        </div>

        <div style="margin-top: 50px;">
            <a href="/" class="btn-appliquer" style="padding: 15px 40px; font-size: 1.1rem;">Retour à l'accueil</a>
        </div>
    </div>
</div>
{% endblock %}