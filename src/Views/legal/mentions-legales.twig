{% extends 'layout.twig' %}
{% block title %}Mentions Légales - CESI Ton Stage{% endblock %}

{% block content %}
<div class="container" style="max-width: 900px; padding: 60px 20px; line-height: 1.8;">
    <div class="card" style="padding: 40px; border-top: 5px solid #38bdf8;">
        <h1 style="color: #fff; margin-bottom: 40px; font-size: 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 20px;">
            Mentions Légales
        </h1>
        
        <div style="display: flex; flex-direction: column; gap: 40px;">
            <section>
                <h2 style="color: #38bdf8; font-size: 1.6rem; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span></span> 1. Éditeur du site
                </h2>
                <p style="font-size: 1.1rem; color: #cbd5e1; padding-left: 35px;">
                    Le site <strong>CESI Ton Stage</strong> est un projet pédagogique réalisé par des étudiants du CESI.<br>
                    <strong>Responsable de publication :</strong> BLANDEAU Adrien<br>
                    <strong>Adresse :</strong> CESI Campus d'Angoulême.
                </p>
            </section>

            <section>
                <h2 style="color: #38bdf8; font-size: 1.6rem; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span></span> 2. Hébergement
                </h2>
                <p style="font-size: 1.1rem; color: #cbd5e1; padding-left: 35px;">
                    Ce site est actuellement hébergé sur un serveur local de développement (Environnement Fedora / Apache) dans le cadre d'un module d'apprentissage du CESI.
                </p>
            </section>

            <section>
                <h2 style="color: #38bdf8; font-size: 1.6rem; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                    <span></span> 3. Propriété intellectuelle
                </h2>
                <p style="font-size: 1.1rem; color: #cbd5e1; padding-left: 35px;">
                    L'ensemble des contenus présents sur ce site (textes, logos, code source) est protégé par les lois françaises sur la propriété intellectuelle. Toute reproduction est interdite sans accord préalable.
                </p>
            </section>
        </div>
    </div>
</div>
{% endblock %}