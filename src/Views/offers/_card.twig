<article class="offre" style="position: relative; padding: 25px; border-left: 4px solid #38bdf8; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 15px; margin-bottom: 20px; border-radius: 0 10px 10px 0;">
    
    <div class="entete-offre" style="display: grid; grid-template-columns: auto 1fr auto; gap: 15px; align-items: center; margin-bottom: 5px;">
        <div style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
            {% if offre.logo_path %}
                <img src="{{ offre.logo_path }}" alt="Logo {{ offre.entreprise_nom }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
            {% else %}
                <img src="https://ui-avatars.com/api/?name={{ offre.entreprise_nom|url_encode }}&background=38bdf8&color=0F172A&size=64&bold=true" alt="Placeholder Logo" style="width: 100%; height: 100%; display: block;">
            {% endif %}
        </div>

        <div>
            <h4 style="margin: 0 0 3px 0; font-size: 1.3rem;">{{ offre.titre }}</h4>
            <div style="display: flex; align-items: center; gap: 10px;">
                <div style="color: #cbd5e1; font-weight: 500; font-size: 1rem;">🏢 {{ offre.entreprise_nom }}</div>
                {% if offre.nb_avis > 0 %}
                    <div style="background: rgba(250, 204, 21, 0.1); color: #facc15; padding: 2px 8px; border-radius: 6px; font-size: 0.85rem; font-weight: bold; border: 1px solid rgba(250, 204, 21, 0.3);" title="{{ offre.nb_avis }} avis">
                        ⭐ {{ offre.moyenne_avis }}
                    </div>
                {% else %}
                    <div style="color: #64748b; font-size: 0.8rem; font-style: italic; background: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 6px;">
                        Nouveau (0 avis)
                    </div>
                {% endif %}
            </div>
        </div>
        
        {% if session.id_user is defined and session.role == 3 %}
            <a href="/wishlist/toggle?id={{ offre.id }}" 
            class="wishlist-btn" 
            onclick="toggleWishlistAjax(event, this, {{ offre.id }});"
            style="color: {{ offre.id in wishlist ? '#ff6b6b' : 'rgba(255, 255, 255, 0.2)' }}; font-size: 1.5rem; text-decoration: none; transition: 0.2s; display: inline-block;" 
            title="Ajouter aux favoris">
                {% if offre.id in wishlist %}❤️{% else %}🤍{% endif %}
            </a>
        {% endif %}
    </div>

    <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
        <span class="badge" style="background: rgba(255,255,255,0.05);">📍 {{ offre.ville }}</span>
        {% if offre.type_contrat %}<span class="badge" style="background: rgba(255,255,255,0.05);">📜 {{ offre.type_contrat }}</span>{% endif %}
        {% if offre.niveau_requis %}<span class="badge" style="background: rgba(255,255,255,0.05);">🎓 {{ offre.niveau_requis }}</span>{% endif %}

        {% if offre.duree %}
        <span class="badge" style="background: rgba(255,255,255,0.05);">⏱️
            {% if offre.duree >= 12 %}
                {% set annees = (offre.duree / 12)|round(0, 'floor') %}
                {% set mois_restants = offre.duree % 12 %}    
                {{ annees }} an{{ annees > 1 ? 's' : '' }}
                {% if mois_restants > 0 %} {{ mois_restants }} mois{% endif %}
            {% else %}
                {{ offre.duree }} mois
            {% endif %}
        </span>
        {% endif %}
        
        {% if offre.remuneration %}<span class="badge" style="background: rgba(255,255,255,0.05);">💰 {{ offre.remuneration }}€/m</span>{% endif %}
        
        <span class="badge" style="background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.4); color: #38bdf8;">
            👥 {{ offre.nb_candidatures }} postulant{{ offre.nb_candidatures > 1 ? 's' : '' }}
        </span>
    </div>

    {% if offre.competences %}
    <div style="display: flex; gap: 6px; flex-wrap: wrap;">
        {% for comp in offre.competences|split(', ') %}
            <span style="background: transparent; border: 1px solid rgba(255, 255, 255, 0.2); color: #cbd5e1; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem;">
                {{ comp }}
            </span>
        {% endfor %}
    </div>
    {% endif %}

    <p class="texte-offre" style="margin: 0; color: #cbd5e1; line-height: 1.5; font-size: 0.95rem;">
        {{ offre.description|length > 180 ? offre.description|slice(0, 180) ~ '...' : offre.description }}
    </p>

    <div class="actions-offre" style="display: flex; gap: 10px; margin-top: 10px;">
        <a class="btn-simple" style="padding: 8px 18px;" href="/offre/{{ offre.id }}">Voir les détails</a>
        {% if session.role is not defined or session.role == 3 %}
            <a class="btn-simple primary" style="padding: 8px 18px; font-weight: bold;" href="/postuler/{{ offre.id }}">POSTULER</a>
        {% endif %}
    </div>
</article>