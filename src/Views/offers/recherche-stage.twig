{% extends 'layout.twig' %}

{% block title %}Recherche de stage - CESI Ton Stage{% endblock %}

{% block content %}
<section class="entete-page">
    
    {% if session.id_user is defined %}
    <section class="container" style="margin-bottom: 30px;">
        <h3 style="color: #38bdf8; margin-bottom: 15px; font-size: 1.2rem;">📊 L'état du marché en direct</h3>
        
        <div style="display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 20px; padding-bottom: 15px; scrollbar-width: thin; scrollbar-color: #38bdf8 rgba(255,255,255,0.05);">
            
            <div class="card" style="scroll-snap-align: start; min-width: 280px; flex-shrink: 0; background: linear-gradient(135deg, rgba(56,189,248,0.1), transparent); border-color: rgba(56,189,248,0.3);">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase;">Total des offres</div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #fff;">{{ stats.total_offres|default(0) }}</div>
                <div style="font-size: 0.85rem; color: #10b981;">Disponibles en base</div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 280px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase;">Moyenne de postulants</div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #38bdf8;">{{ stats.moyenne_candidatures|default(0) }}</div>
                <div style="font-size: 0.85rem; color: #cbd5e1;">Candidatures / Offre</div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 320px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase; margin-bottom: 10px;">Répartition par durée</div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    {% for rep in stats.repartition_duree|default([]) %}
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: #cbd5e1; font-size: 0.9rem;">{{ rep.duree }} mois</span>
                            <span class="badge" style="background: rgba(255,255,255,0.1);">{{ rep.nb }} offre(s)</span>
                        </div>
                    {% else %}
                        <span style="color: #64748b; font-size: 0.9rem;">Données insuffisantes</span>
                    {% endfor %}
                </div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 350px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase; margin-bottom: 10px;">🔥 Top Wishlist</div>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                    {% for top in stats.top_wishlist|default([]) %}
                        <li style="display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem;">
                            <span style="color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px;">{{ top.titre }}</span>
                            <span style="color: #ff6b6b; font-weight: bold;">{{ top.nb_ajouts }} ❤️</span>
                        </li>
                    {% else %}
                        <li style="color: #64748b; font-size: 0.9rem;">Aucun favori enregistré</li>
                    {% endfor %}
                </ul>
            </div>

        </div>
    </section>
    {% endif %}

    <div class="container">
        <h2>Recherche de stage</h2>
        <p>Utilisez les filtres afin trouver l'offre idéale pour votre profil.</p>
    </div>
</section>

<section class="zone-principale">
    <div class="container">
        <div class="bloc-contenu bloc-sans-survol">
            
            <div class="mobile-filter-bar">
                <button id="btn-toggle-filtres" class="btn-simple">⚙️ Afficher les filtres</button>
            </div>

            <div class="mise-en-page-recherche">

                <aside class="zone-filtres" id="zone-filtres" aria-label="Filtres de recherche">
                    <button id="btn-close-filtres" class="btn-simple secondary">✖ Fermer les filtres</button>
                    <h3>Filtres</h3>
                   
                    <form action="/offres#resultats" method="get" class="formulaire">
                        <div class="ligne-champ">
                            <label for="motscles">Mots-clés</label>
                            <input id="motscles" name="q" type="search" placeholder="ex : dev web, data..." value="{{ queryParams.q|default('') }}"/>
                        </div>
                        
                        <div class="ligne-champ">
                            <label for="ville">Ville</label>
                            <select id="ville" name="ville">
                                <option value="">Toutes les villes</option>
                                {% for v in villes %}
                                    <option value="{{ v }}" {% if queryParams.ville == v %}selected{% endif %}>{{ v }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <div class="ligne-champ">
                            <label for="type_contrat">Contrat</label>
                            <select id="type_contrat" name="type_contrat">
                                <option value="">Tous</option>
                                <option value="Stage" {% if queryParams.type_contrat == 'Stage' %}selected{% endif %}>Stage</option>
                                <option value="Alternance" {% if queryParams.type_contrat == 'Alternance' %}selected{% endif %}>Alternance</option>
                            </select>
                        </div>
           
                        <div class="ligne-champ">
                            <label for="domaine">Domaine</label>
                            <select id="domaine" name="domaine">
                                <option value="">Tous les domaines</option>
                                {% for dom in domaines %}
                                    <option value="{{ dom }}" {% if queryParams.domaine == dom %}selected{% endif %}>{{ dom }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="ligne-champ">
                            <label for="niveau">Niveau requis</label>
                            <select id="niveau" name="niveau_requis">
                                <option value="">Tous les niveaux</option>
                                {% for niv in niveaux %}
                                    <option value="{{ niv }}" {% if queryParams.niveau_requis == niv %}selected{% endif %}>{{ niv }}</option>
                                {% endfor %}
                            </select>
                        </div>
    
                        <div class="ligne-champ">
                            <label for="duree_plage">Durée du stage</label>
                            <select id="duree_plage" name="duree_plage" onchange="updateDureeFilters(this.value)">
                                <option value="">Tous les stages</option>
                                <option value="1-2" {% if queryParams.duree_plage == '1-2' %}selected{% endif %}>Stage court (1-2 mois)</option>
                                <option value="3-4" {% if queryParams.duree_plage == '3-4' %}selected{% endif %}>Stage moyen (3-4 mois)</option>
                                <option value="5-6" {% if queryParams.duree_plage == '5-6' %}selected{% endif %}>Stage long (5-6 mois)</option>
                                <option value="12-12" {% if queryParams.duree_plage == '12-12' %}selected{% endif %}>Alternance (1 an)</option>
                                <option value="24-24" {% if queryParams.duree_plage == '24-24' %}selected{% endif %}>Alternance (2 ans)</option>
                            </select>
                            <input type="hidden" name="duree_min" id="duree_min" value="{{ queryParams.duree_min|default('') }}">
                            <input type="hidden" name="duree_max" id="duree_max" value="{{ queryParams.duree_max|default('') }}">
                        </div>

                        <div class="ligne-champ">
                            <label for="date-debut">Date de début</label>
                            <input id="date-debut" name="date_debut" type="date" value="{{ queryParams.date_debut|default('') }}"/>
                        </div>
                        
                        <div class="actions-formulaire" style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px; position: relative; z-index: 10;">
                            <button class="btn-appliquer" type="submit" style="width: 100%; cursor: pointer;">Appliquer</button>
                            <a href="/offres" class="btn-reset" style="display: block; text-align: center; width: 100%; box-sizing: border-box;">Réinitialiser</a>
                        </div>
                    </form>
                </aside>

                <section id="resultats" class="zone-resultats" aria-label="Résultats">
                    <h3>Offres ({{ offres|length }})</h3>
                    
                    {% for offre in offres %}
                        {% include 'offers/_card.twig' %}
                    {% else %}
                        <div class="card" style="text-align: center; padding: 40px;">
                            <h3 style="color: #fff;">Aucune offre trouvée 😢</h3>
                            <p style="color: #94a3b8;">Essayez de modifier vos filtres ou de faire une nouvelle recherche.</p>
                        </div>
                    {% endfor %}

                    {% if totalPages is defined and totalPages > 0 %}
                    <div style="margin-top: 40px; text-align: center;">
                        <p class="hint">Page {{ currentPage }} sur {{ totalPages }}</p>
                    </div>
                    
                    <div class="pagination">
                        <a href="?page=1{{ queryString }}" class="{{ currentPage == 1 ? 'disabled' : '' }}">«</a>
                        <a href="?page={{ currentPage - 1 }}{{ queryString }}" class="{{ currentPage == 1 ? 'disabled' : '' }}">‹</a>

                        {% for i in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                            <a href="?page={{ i }}{{ queryString }}" class="{{ i == currentPage ? 'active' : '' }}">{{ i }}</a>
                        {% endfor %}

                        <a href="?page={{ currentPage + 1 }}{{ queryString }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">›</a>
                        <a href="?page={{ totalPages }}{{ queryString }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">»</a>
                    </div>
                    {% endif %}

                </section>
            </div>
        </div>
    </div>
</section>

<script>
    function updateDureeFilters(value) {
        if (!value) { document.getElementById('duree_min').value = ''; document.getElementById('duree_max').value = ''; return; }
        var plage = value.split('-');
        document.getElementById('duree_min').value = plage[0];
        document.getElementById('duree_max').value = plage[1];
    }
</script>
{% endblock %}