{% extends 'layout.twig' %}
{% block title %}Recherche de stage - CESI Ton Stage{% endblock %}

{% block content %}
<section class="entete-page">
    <div class="container">
        <h2>Recherche de stage</h2>
        <p>Utilisez les filtres afin trouver le stage idéal pour votre profil.</p>
    </div>
</section>

<section class="zone-principale">
    <div class="container">
        <div class="bloc-contenu bloc-sans-survol">
            <div class="mobile-filter-bar">
                <button id="btn-toggle-filtres" class="btn-simple">⚙️ Afficher les filtres</button>
            </div>

            <div class="mise-en-page-recherche">
                <aside class="zone-filtres" id="zone-filtres">
                    <button id="btn-close-filtres" class="btn-simple secondary">✖ Fermer les filtres</button>
                    <h3>Filtres</h3>
                    <form action="/offres" method="get" class="formulaire">
                        <div class="ligne-champ">
                            <label for="motscles">Mots-clés</label>
                            <input id="motscles" name="q" type="search" placeholder="ex : dev web..." value="{{ queryParams.q }}"/>
                        </div>
                        <div class="ligne-champ">
                            <label for="ville">Ville</label>
                            <select id="ville" name="ville">
                                <option value="">Toutes les villes</option>
                                <option value="Paris" {{ queryParams.ville == 'Paris' ? 'selected' : '' }}>Paris</option>
                                <option value="Lyon" {{ queryParams.ville == 'Lyon' ? 'selected' : '' }}>Lyon</option>
                                <option value="Bordeaux" {{ queryParams.ville == 'Bordeaux' ? 'selected' : '' }}>Bordeaux</option>
                            </select>
                        </div>
                        <div class="ligne-champ">
                            <label for="domaine">Domaine</label>
                            <select id="domaine" name="domaine">
                                <option value="">Tous les domaines</option>
                                {% for dom in domaines %}
                                    <option value="{{ dom }}" {{ queryParams.domaine == dom ? 'selected' : '' }}>{{ dom }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="ligne-champ">
                            <label for="duree">Durée minimum (mois)</label>
                            <select id="duree" name="duree">
                                <option value="">Peu importe</option>
                                <option value="1" {{ queryParams.duree == '1' ? 'selected' : '' }}>1-2 mois</option>
                                <option value="4" {{ queryParams.duree == '4' ? 'selected' : '' }}>4 mois+</option>
                                <option value="6" {{ queryParams.duree == '6' ? 'selected' : '' }}>6 mois+</option>
                                <option value="12" {{ queryParams.duree == '12' ? 'selected' : '' }}>1 an+</option>
                                <option value="24" {{ queryParams.duree == '24' ? 'selected' : '' }}>2 ans+</option>
                            </select>
                        </div>
                        <div class="actions-formulaire" style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px;">
                            <button class="btn-appliquer" type="submit" style="width: 100%;">Appliquer</button>
                            <a href="/offres" class="btn-reset" style="display: block; text-align: center; width: 100%;">Réinitialiser</a>
                        </div>
                    </form>
                </aside>

                <section class="zone-resultats">
                    {% for offre in offres %}
                    <article class="offre" style="position: relative; padding: 25px; border-left: 4px solid #38bdf8; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 15px; margin-bottom: 20px; border-radius: 0 10px 10px 0;">
                        <div class="entete-offre" style="display: grid; grid-template-columns: auto 1fr auto; gap: 15px; align-items: center;">
                            <div style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
                                <img src="{{ offre.logo_path|default('https://ui-avatars.com/api/?name=' ~ offre.entreprise_nom|url_encode) }}" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>
                            <div>
                                <h4 style="margin: 0; font-size: 1.3rem;">{{ offre.titre }}</h4>
                                <div style="color: #cbd5e1;">🏢 {{ offre.entreprise_nom }}</div>
                            </div>
                            <a href="/wishlist/toggle?id={{ offre.id }}" 
                                class="wishlist-btn" 
                                onclick="localStorage.setItem('scrollPos', window.scrollY);"
                                style="color: {{ offre.id in wishlist ? '#ff6b6b' : 'rgba(255, 255, 255, 0.3)' }}; text-decoration: none; font-size: 1.5rem;">
                                {{ offre.id in wishlist ? '❤️' : '🤍' }}
                            </a>
                        </div>

                        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                            <span class="badge">📍 {{ offre.ville }}</span>
                            {% if offre.duree %}
                            <span class="badge" style="background: rgba(255,255,255,0.05);">⏱️
                                {% if offre.duree >= 12 %}
                                    {% set annees = (offre.duree / 12)|round(0, 'floor') %}
                                    {% set mois_restants = offre.duree % 12 %}    
                                    {{ annees }} an{{ annees > 1 ? 's' : '' }}{% if mois_restants > 0 %} {{ mois_restants }} mois{% endif %}
                                {% else %}
                                    {{ offre.duree }} mois
                                {% endif %}
                            </span>
                            {% endif %}
                        </div>

                        <p style="color: #cbd5e1; font-size: 0.95rem;">{{ offre.description|length > 180 ? offre.description|slice(0, 180) ~ '...' : offre.description }}</p>

                        <div style="display: flex; gap: 10px; margin-top: 10px;">
                            <a class="btn-simple" href="/offre/{{ offre.id }}">Voir les détails</a>
                            <a class="btn-simple primary" href="/postuler/{{ offre.id }}">POSTULER</a>
                        </div>
                    </article>
                    {% endfor %}

                    {# Pagination... #}
                </section>
            </div>
        </div>
    </div>
</section>
{% endblock %}