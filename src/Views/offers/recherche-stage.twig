{% extends 'layout.twig' %}

{% block title %}Recherche de stage - CESI Ton Stage{% endblock %}

{% block content %}
<section class="entete-page">
    
    {% if session.id_user is defined %}
    <section class="container" style="margin-bottom: 30px;">
        <h3 style="color: #38bdf8; margin-bottom: 15px; font-size: 1.2rem;">📊 L'état du marché en direct</h3>
        
        <div style="display: flex; overflow-x: auto; scroll-snap-type: x mandatory; gap: 20px; padding-bottom: 15px; scrollbar-width: thin; scrollbar-color: #38bdf8 rgba(255,255,255,0.05);">
            
            <div class="card" style="scroll-snap-align: start; min-width: 280px; flex-shrink: 0; background: linear-gradient(135deg, rgba(56,189,248,0.1), transparent); border-color: rgba(56,189,248,0.3);">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase;">Total des offres</div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #fff;">{{ stats.total_offres|default(0) }}</div>
                <div style="font-size: 0.85rem; color: #10b981;">Disponibles en base</div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 280px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase;">Moyenne de postulants</div>
                <div style="font-size: 2.5rem; font-weight: bold; color: #38bdf8;">{{ stats.moyenne_candidatures|default(0) }}</div>
                <div style="font-size: 0.85rem; color: #cbd5e1;">Candidatures / Offre</div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 320px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase; margin-bottom: 10px;">Répartition par durée</div>
                <div style="display: flex; flex-direction: column; gap: 8px;">
                    {% for rep in stats.repartition_duree|default([]) %}
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="color: #cbd5e1; font-size: 0.9rem;">{{ rep.duree }} mois</span>
                            <span class="badge" style="background: rgba(255,255,255,0.1);">{{ rep.nb }} offre(s)</span>
                        </div>
                    {% else %}
                        <span style="color: #64748b; font-size: 0.9rem;">Données insuffisantes</span>
                    {% endfor %}
                </div>
            </div>

            <div class="card" style="scroll-snap-align: start; min-width: 350px; flex-shrink: 0;">
                <div style="font-size: 0.9rem; color: #94a3b8; text-transform: uppercase; margin-bottom: 10px;">🔥 Top Wishlist</div>
                <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px;">
                    {% for top in stats.top_wishlist|default([]) %}
                        <li style="display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem;">
                            <span style="color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 220px;">{{ top.titre }}</span>
                            <span style="color: #ff6b6b; font-weight: bold;">{{ top.nb_ajouts }} ❤️</span>
                        </li>
                    {% else %}
                        <li style="color: #64748b; font-size: 0.9rem;">Aucun favori enregistré</li>
                    {% endfor %}
                </ul>
            </div>

        </div>
    </section>
    {% endif %}

    <div class="container">
        <h2>Recherche de stage</h2>
        <p>Utilisez les filtres afin trouver le stage idéal pour votre profil.</p>
    </div>
</section>

<section class="zone-principale">
    <div class="container">
        <div class="bloc-contenu bloc-sans-survol">
            
            <div class="mobile-filter-bar">
                <button id="btn-toggle-filtres" class="btn-simple">⚙️ Afficher les filtres</button>
            </div>

            <div class="mise-en-page-recherche">

                <aside class="zone-filtres" id="zone-filtres" aria-label="Filtres de recherche">
                    <button id="btn-close-filtres" class="btn-simple secondary">✖ Fermer les filtres</button>
                    <h3>Filtres</h3>
                    <form action="/offres" method="get" class="formulaire">
                        <div class="ligne-champ">
                            <label for="motscles">Mots-clés</label>
                            <input id="motscles" name="q" type="search" placeholder="ex : dev web, data..." value="{{ queryParams.q|default('') }}"/>
                        </div>
                        <div class="ligne-champ">
                            <label for="ville">Ville</label>
                            <select id="ville" name="ville">
                                <option value="">Toutes les villes</option>
                                <option value="Angoulême" {% if queryParams.ville == 'Angoulême' %}selected{% endif %}>Angoulême</option>
                                <option value="Bordeaux" {% if queryParams.ville == 'Bordeaux' %}selected{% endif %}>Bordeaux</option>
                                <option value="Lyon" {% if queryParams.ville == 'Lyon' %}selected{% endif %}>Lyon</option>
                                <option value="Paris" {% if queryParams.ville == 'Paris' %}selected{% endif %}>Paris</option>
                                <option value="Toulouse" {% if queryParams.ville == 'Toulouse' %}selected{% endif %}>Toulouse</option>
                                <option value="Nantes" {% if queryParams.ville == 'Nantes' %}selected{% endif %}>Nantes</option>
                            </select>
                        </div>
                        <div class="ligne-champ">
                            <label for="type_contrat">Contrat</label>
                            <select id="type_contrat" name="type_contrat">
                                <option value="">Tous</option>
                                <option value="Stage" {% if queryParams.type_contrat == 'Stage' %}selected{% endif %}>Stage</option>
                                <option value="Alternance" {% if queryParams.type_contrat == 'Alternance' %}selected{% endif %}>Alternance</option>
                            </select>
                        </div>
                        
                        <div class="ligne-champ">
                            <label for="domaine">Domaine</label>
                            <select id="domaine" name="domaine">
                                <option value="">Tous les domaines</option>
                                {% for dom in domaines %}
                                    <option value="{{ dom }}" {% if queryParams.domaine == dom %}selected{% endif %}>{{ dom }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="ligne-champ">
                            <label for="niveau">Niveau requis</label>
                            <select id="niveau" name="niveau_requis">
                                <option value="">Tous les niveaux</option>
                                {% for niv in niveaux %}
                                    <option value="{{ niv }}" {% if queryParams.niveau_requis == niv %}selected{% endif %}>{{ niv }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <div class="ligne-champ">
                            <label for="duree">Durée minimum (mois)</label>
                            <select id="duree" name="duree">
                                <option value="">Peu importe</option>
                                <option value="1" {% if queryParams.duree == '1' %}selected{% endif %}>Stage court (1-2 mois)</option>
                                <option value="4" {% if queryParams.duree == '4' %}selected{% endif %}>Stage long (4 mois+)</option>
                                <option value="6" {% if queryParams.duree == '6' %}selected{% endif %}>Semestre (6 mois+)</option>
                                <option value="12" {% if queryParams.duree == '12' %}selected{% endif %}>Alternance (1 an+)</option>
                                <option value="24" {% if queryParams.duree == '24' %}selected{% endif %}>Alternance (2 ans+)</option>
                            </select>
                        </div>
                        <div class="ligne-champ">
                            <label for="date-debut">Date de début</label>
                            <input id="date-debut" name="date_debut" type="date" value="{{ queryParams.date_debut|default('') }}"/>
                        </div>
                        
                        <div class="actions-formulaire" style="display: flex; flex-direction: column; gap: 10px; margin-top: 20px; position: relative; z-index: 10;">
                            <button class="btn-appliquer" type="submit" style="width: 100%; cursor: pointer;">Appliquer</button>
                            <a href="/offres" class="btn-reset" style="display: block; text-align: center; width: 100%; box-sizing: border-box;">Réinitialiser</a>
                        </div>
                    </form>
                </aside>

                <section class="zone-resultats" aria-label="Résultats">
                    <h3>Offres ({{ offres|length }})</h3>
                    
                    {% for offre in offres %}
                    <article class="offre" style="position: relative; padding: 25px; border-left: 4px solid #38bdf8; background: rgba(255,255,255,0.02); display: flex; flex-direction: column; gap: 15px; margin-bottom: 20px; border-radius: 0 10px 10px 0;">
                        
                        <div class="entete-offre" style="display: grid; grid-template-columns: auto 1fr auto; gap: 15px; align-items: center; margin-bottom: 5px;">
                            
                            <div style="width: 50px; height: 50px; border-radius: 8px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
                                {% if offre.logo_path %}
                                    <img src="{{ offre.logo_path }}" alt="Logo {{ offre.entreprise_nom }}" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                                {% else %}
                                    <img src="https://ui-avatars.com/api/?name={{ offre.entreprise_nom|url_encode }}&background=38bdf8&color=0F172A&size=64&bold=true" alt="Placeholder Logo" style="width: 100%; height: 100%; display: block;">
                                {% endif %}
                            </div>

                            <div>
                                <h4 style="margin: 0 0 3px 0; font-size: 1.3rem;">{{ offre.titre }}</h4>
                                <div style="display: flex; align-items: center; gap: 10px;">
                                    <div style="color: #cbd5e1; font-weight: 500; font-size: 1rem;">🏢 {{ offre.entreprise_nom }}</div>
                                    {% if offre.nb_avis > 0 %}
                                        <div style="background: rgba(250, 204, 21, 0.1); color: #facc15; padding: 2px 8px; border-radius: 6px; font-size: 0.85rem; font-weight: bold; border: 1px solid rgba(250, 204, 21, 0.3);" title="{{ offre.nb_avis }} avis">
                                            ⭐ {{ offre.moyenne_avis }}
                                        </div>
                                    {% else %}
                                        <div style="color: #64748b; font-size: 0.8rem; font-style: italic; background: rgba(255,255,255,0.05); padding: 2px 8px; border-radius: 6px;">
                                            Nouveau (0 avis)
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                            
                            {% if session.id_user is defined and session.role == 3 %}
                                <a href="/wishlist/toggle?id={{ offre.id }}" 
                                class="wishlist-btn" 
                                onclick="localStorage.setItem('scrollPos', window.scrollY);"
                                style="color: {{ offre.id in wishlist ? '#ff6b6b' : 'rgba(255, 255, 255, 0.2)' }}; font-size: 1.5rem; text-decoration: none; transition: 0.2s;" 
                                title="Ajouter aux favoris">
                                    {% if offre.id in wishlist %}❤️{% else %}🤍{% endif %}
                                </a>
                            {% endif %}
                        </div>

                        <div style="display: flex; gap: 8px; flex-wrap: wrap; align-items: center;">
                            <span class="badge" style="background: rgba(255,255,255,0.05);">📍 {{ offre.ville }}</span>
                            {% if offre.type_contrat %}<span class="badge" style="background: rgba(255,255,255,0.05);">📜 {{ offre.type_contrat }}</span>{% endif %}
                            
                            {% if offre.niveau_requis %}<span class="badge" style="background: rgba(255,255,255,0.05);">🎓 {{ offre.niveau_requis }}</span>{% endif %}

                            {% if offre.duree %}
                            <span class="badge" style="background: rgba(255,255,255,0.05);">⏱️
                                {% if offre.duree >= 12 %}
                                    {% set annees = (offre.duree / 12)|round(0, 'floor') %}
                                    {% set mois_restants = offre.duree % 12 %}    
                                    {{ annees }} an{{ annees > 1 ? 's' : '' }}
                                    {% if mois_restants > 0 %} {{ mois_restants }} mois{% endif %}
                                {% else %}
                                    {{ offre.duree }} mois
                                {% endif %}
                            </span>
                            {% endif %}
                            
                            {% if offre.remuneration %}<span class="badge" style="background: rgba(255,255,255,0.05);">💰 {{ offre.remuneration }}€/m</span>{% endif %}
                            
                            <span class="badge" style="background: rgba(56, 189, 248, 0.1); border: 1px solid rgba(56, 189, 248, 0.4); color: #38bdf8;">
                                👥 {{ offre.nb_candidatures }} postulant{{ offre.nb_candidatures > 1 ? 's' : '' }}
                            </span>
                        </div>

                        {% if offre.competences %}
                        <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                            {% for comp in offre.competences|split(', ') %}
                                <span style="background: transparent; border: 1px solid rgba(255, 255, 255, 0.2); color: #cbd5e1; padding: 2px 10px; border-radius: 12px; font-size: 0.75rem;">
                                    {{ comp }}
                                </span>
                            {% endfor %}
                        </div>
                        {% endif %}

                        <p class="texte-offre" style="margin: 0; color: #cbd5e1; line-height: 1.5; font-size: 0.95rem;">
                            {{ offre.description|length > 180 ? offre.description|slice(0, 180) ~ '...' : offre.description }}
                        </p>

                        <div class="actions-offre" style="display: flex; gap: 10px; margin-top: 10px;">
                            <a class="btn-simple" style="padding: 8px 18px;" href="/offre/{{ offre.id }}">Voir les détails</a>
                            {% if session.role is not defined or session.role == 3 %}
                                <a class="btn-simple primary" style="padding: 8px 18px; font-weight: bold;" href="/postuler/{{ offre.id }}">POSTULER</a>
                            {% endif %}
                        </div>
                    </article>
                    {% else %}
                        <div class="card" style="text-align: center; padding: 40px;">
                            <h3 style="color: #fff;">Aucune offre trouvée 😢</h3>
                            <p style="color: #94a3b8;">Essayez de modifier vos filtres ou de faire une nouvelle recherche.</p>
                        </div>
                    {% endfor %}

                    {% if totalPages is defined and totalPages > 0 %}
                    <div style="margin-top: 40px; text-align: center;">
                        <p class="hint">Page {{ currentPage }} sur {{ totalPages }}</p>
                    </div>
                    
                    <div class="pagination">
                        <a href="?page=1{{ queryString }}" class="{{ currentPage == 1 ? 'disabled' : '' }}">«</a>
                        <a href="?page={{ currentPage - 1 }}{{ queryString }}" class="{{ currentPage == 1 ? 'disabled' : '' }}">‹</a>

                        {% for i in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                            <a href="?page={{ i }}{{ queryString }}" class="{{ i == currentPage ? 'active' : '' }}">{{ i }}</a>
                        {% endfor %}

                        <a href="?page={{ currentPage + 1 }}{{ queryString }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">›</a>
                        <a href="?page={{ totalPages }}{{ queryString }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">»</a>
                    </div>
                    {% endif %}

                </section>
            </div>
        </div>
    </div>
</section>
{% endblock %}