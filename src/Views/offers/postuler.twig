{% extends 'layout.twig' %}
{% block title %}Postuler - {{ offre.titre }}{% endblock %}

{% block content %}
<div class="entete-page">
    <h2>Envoyer ma candidature</h2>
    <p class="hint">Pour l'offre : <strong>{{ offre.titre }}</strong> chez <strong>{{ offre.entreprise_nom }}</strong></p>
</div>

<div class="container" style="max-width: 600px;">
    <div class="cardCVLM" style="padding: 30px;">
        
        <div style="background: rgba(56, 189, 248, 0.1); border-left: 4px solid #38bdf8; padding: 15px 20px; border-radius: 0 8px 8px 0; margin-bottom: 25px;">
            <h4 style="color: #38bdf8; margin-bottom: 8px; font-size: 1.1rem;">Que se passe-t-il ensuite ?</h4>
            <p style="font-size: 0.95rem; color: #e9eef7; line-height: 1.5;">
                Votre dossier sera transmis en toute sécurité au service recrutement de <strong>{{ offre.entreprise_nom }}</strong>. 
                Si votre profil correspond à leurs attentes, un responsable vous contactera directement sous 72h pour planifier un premier entretien. 
                Vérifiez bien que votre CV est à jour !
            </p>
        </div>

        <form action="/candidature/envoyer" method="POST" enctype="multipart/form-data">
            
            <input type="hidden" name="id_offre" value="{{ offre.id }}">

            <div class="ligne-champ" style="margin-bottom: 20px;">
                <label for="cv">Votre CV (Format PDF)</label>
                <input type="file" id="cv" name="cv" accept=".pdf" required class="btn-file-custom" style="padding-top: 10px;">
            </div>
            
            <div class="ligne-champ" style="margin-bottom: 20px;">
                <label for="lm">Lettre de motivation (Format PDF)</label>
                <input type="file" id="lm" name="lm" accept=".pdf" required class="btn-file-custom" style="padding-top: 10px;">
            </div>

            <div class="ligne-champ" style="margin-bottom: 25px;">
                <label for="message" style="font-size: 1.1rem; color: #38bdf8;">Ajouter un message (Optionnel)</label>
                <p class="hint" style="margin-bottom: 10px;">Entrez un message personnalisé pour l'employeur afin d'appuyer votre candidature.</p>
                <textarea id="message" name="message" rows="5" placeholder="Votre message personnalisé ici..."></textarea>
            </div>

            <div style="display: flex; gap: 15px; margin-top: 20px;">
                <a href="/offre/{{ offre.id }}" class="btn-reset" style="flex: 1; text-align: center; padding: 12px;">Annuler</a>
                <button type="submit" class="btn-appliquer" style="flex: 2; padding: 12px; font-size: 1.1rem;">Envoyer ma candidature</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}