{% extends 'layout.twig' %}

{% block title %}Mes Candidatures - CESI Ton Stage{% endblock %}

{% block content %}
<section class="entete-page">
    <div class="container">
        <h2>Mes Candidatures</h2>
        <p>Retrouvez l'historique de toutes vos demandes de stage et les documents que vous avez envoyés.</p>
    </div>
</section>

<section class="zone-principale">
    <div class="container" style="max-width: 900px;">
        {% for candidature in candidatures %}
            <article class="card" style="margin-bottom: 25px; border-left: 4px solid #10b981; padding: 25px;">
                
                <div class="entete-offre" style="display: grid; grid-template-columns: auto 1fr auto; gap: 15px; align-items: center; margin-bottom: 20px;">
                    <div style="width: 60px; height: 60px; border-radius: 8px; overflow: hidden; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
                        {% if candidature.logo_path %}
                            <img src="{{ candidature.logo_path }}" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;">
                        {% else %}
                            <img src="https://ui-avatars.com/api/?name={{ candidature.entreprise_nom|url_encode }}&background=38bdf8&color=0F172A" alt="Logo" style="width: 100%; height: 100%; object-fit: cover;">
                        {% endif %}
                    </div>
                    <div>
                        <h3 style="margin: 0 0 5px 0; font-size: 1.4rem; color: #fff;">{{ candidature.titre }}</h3>
                        <div style="color: #38bdf8; font-weight: 500;">🏢 {{ candidature.entreprise_nom }}</div>
                    </div>
                    <div style="text-align: right;">
                        <span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981; border-color: rgba(16, 185, 129, 0.3);">
                            ✅ Envoyée le {{ candidature.date_candidature|date("d/m/Y") }}
                        </span>
                    </div>
                </div>

                <hr style="border: none; border-top: 1px solid rgba(255,255,255,0.1); margin: 20px 0;">

                <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 20px;">
                    <h4 style="color: #cbd5e1; margin-bottom: 15px; font-size: 1rem;">Pièces jointes à ma candidature :</h4>
                    
                    <div style="display: flex; gap: 15px; flex-wrap: wrap; margin-bottom: {% if candidature.message %}20px{% else %}0{% endif %};">
                        
                        {% if candidature.cv_path %}
                            <div style="display: flex; align-items: center; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 6px 12px; gap: 10px;">
                                <span style="font-size: 1.2rem;"></span>
                                <span style="color: #cbd5e1; font-size: 0.9rem;">CV_{{ candidature.entreprise_nom|replace({' ': ''}) }}.pdf</span>
                                
                                <a href="{{ candidature.cv_path }}" download="CV_{{ candidature.entreprise_nom|replace({' ': ''}) }}.pdf" title="Télécharger le CV" style="background: #38bdf8; color: #0f172a; padding: 4px 8px; border-radius: 4px; text-decoration: none; font-size: 0.9rem; margin-left: 10px; transition: 0.2s;" onmouseover="this.style.background='#0284c7'; this.style.color='#fff';" onmouseout="this.style.background='#38bdf8'; this.style.color='#0f172a';">
                                    ⬇️
                                </a>
                            </div>
                        {% endif %}
                        
                        {% if candidature.lm_path %}
                            <div style="display: flex; align-items: center; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 6px 12px; gap: 10px;">
                                <span style="font-size: 1.2rem;"></span>
                                <span style="color: #cbd5e1; font-size: 0.9rem;">LM_{{ candidature.entreprise_nom|replace({' ': ''}) }}.pdf</span>
                                
                                <a href="{{ candidature.lm_path }}" download="LM_{{ candidature.entreprise_nom|replace({' ': ''}) }}.pdf" title="Télécharger la lettre" style="background: #38bdf8; color: #0f172a; padding: 4px 8px; border-radius: 4px; text-decoration: none; font-size: 0.9rem; margin-left: 10px; transition: 0.2s;" onmouseover="this.style.background='#0284c7'; this.style.color='#fff';" onmouseout="this.style.background='#38bdf8'; this.style.color='#0f172a';">
                                    ⬇️
                                </a>
                            </div>
                        {% endif %}

                    </div>

                    {% if candidature.message %}
                        <div style="background: rgba(255,255,255,0.03); border-left: 3px solid #38bdf8; padding: 15px; border-radius: 0 8px 8px 0;">
                            <strong style="display: block; color: #94a3b8; font-size: 0.85rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px;">Mon mot d'accompagnement :</strong>
                            <p style="color: #e9eef7; margin: 0; font-style: italic; line-height: 1.5;">"{{ candidature.message }}"</p>
                        </div>
                    {% endif %}
                </div>

                <div style="margin-top: 20px; display: flex; justify-content: flex-end;">
                    <a href="/offre/{{ candidature.id }}" class="btn-simple secondary" style="font-size: 0.9rem;">Revoir l'offre originale ›</a>
                </div>
            </article>
        {% else %}
            <div class="card" style="text-align: center; padding: 50px 20px;">
                <div style="font-size: 4rem; margin-bottom: 20px;">📝</div>
                <h3 style="color: #fff; margin-bottom: 10px;">Aucune candidature pour le moment</h3>
                <p style="color: #94a3b8; margin-bottom: 25px;">N'attendez plus pour trouver le stage de vos rêves !</p>
                <a href="/offres" class="btn-appliquer">Explorer les offres</a>
            </div>
        {% endfor %}

        {% if totalPages is defined and totalPages > 0 %}
        <div class="pagination">
            <a href="?page=1" class="{{ currentPage == 1 ? 'disabled' : '' }}">«</a>
            <a href="?page={{ currentPage - 1 }}" class="{{ currentPage == 1 ? 'disabled' : '' }}">‹</a>

            {% for i in max(1, currentPage - 2)..min(totalPages, currentPage + 2) %}
                <a href="?page={{ i }}" class="{{ i == currentPage ? 'active' : '' }}">{{ i }}</a>
            {% endfor %}

            <a href="?page={{ currentPage + 1 }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">›</a>
            <a href="?page={{ totalPages }}" class="{{ currentPage == totalPages ? 'disabled' : '' }}">»</a>
        </div>
        {% endif %}
    </div>
</section>
{% endblock %}