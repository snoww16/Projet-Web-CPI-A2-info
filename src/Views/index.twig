{% extends 'layout.twig' %}
{% block title %}Accueil - CESI Ton Stage{% endblock %}

{% block content %}
<div class="container" style="padding-top: 30px; padding-bottom: 60px;">

    <section style="background: linear-gradient(135deg, rgba(56,189,248,0.2) 0%, rgba(15,23,42,1) 100%); padding: 60px 20px; text-align: center; border-radius: 15px; margin-bottom: 40px; border: 1px solid rgba(56,189,248,0.3); position: relative; overflow: hidden;">
        <h1 style="font-size: 3rem; margin-bottom: 20px; color: #fff;">Trouvez le stage de vos rêves</h1>
        <p style="font-size: 1.2rem; color: #cbd5e1; max-width: 600px; margin: 0 auto 30px auto;">Accédez à des centaines d'offres exclusives pour les étudiants du CESI. Développez vos compétences et lancez votre carrière dès aujourd'hui.</p>
        <a href="/offres" class="btn-appliquer" style="font-size: 1.2rem; padding: 15px 40px;">Lancer la recherche</a>
    </section>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 50px;">
        {% if session.id_user %}
            <div class="card" style="padding: 30px; text-align: center; background: rgba(255,255,255,0.03);">
                <div style="font-size: 3rem; margin-bottom: 15px;">👤</div>
                <h3>Mon Espace</h3>
                <p style="color: #94a3b8; margin-bottom: 20px;">Gérez vos candidatures, vos favoris et votre profil.</p>
                <a href="/profil" class="btn-simple">Voir mon profil</a>
            </div>
            
            {% if session.role in [1, 2] %}
            <div class="card" style="padding: 30px; text-align: center; background: rgba(255,255,255,0.03); border-color: #38bdf8;">
                <div style="font-size: 3rem; margin-bottom: 15px;">⚙️</div>
                <h3 style="color: #38bdf8;">Administration</h3>
                <p style="color: #94a3b8; margin-bottom: 20px;">Gérez les entreprises, les offres et les utilisateurs.</p>
                <a href="/admin" class="btn-simple">Gérer les entités</a>
            </div>
            {% endif %}
        {% else %}
            <div class="card" style="padding: 30px; text-align: center; background: rgba(255,255,255,0.03);">
                <div style="font-size: 3rem; margin-bottom: 15px;">👋</div>
                <h3>Rejoignez-nous</h3>
                <p style="color: #94a3b8; margin-bottom: 20px;">Créez un compte pour pouvoir postuler aux offres.</p>
                <a href="/login" class="btn-simple">Se connecter</a>
            </div>
        {% endif %}
        
        <div class="card" style="padding: 30px; text-align: center; background: rgba(255,255,255,0.03);">
            <div style="font-size: 3rem; margin-bottom: 15px;">🏢</div>
            <h3>Nos Partenaires</h3>
            <p style="color: #94a3b8; margin-bottom: 20px;">Découvrez les entreprises qui recrutent au CESI.</p>
            <a href="/entreprises" class="btn-simple">Voir les entreprises</a>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px; align-items: start;">
        <section>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px;">
                    <h2 style="margin: 0; font-size: 1.5rem;">🔥 Dernières offres</h2>
                    <a href="/offres" style="color: #38bdf8; text-decoration: none; font-weight: bold;">Voir tout ›</a>
                </div>

                <div style="display: grid; grid-template-columns: 1fr; gap: 15px;">
                    {% for offre in dernieres_offres %}
                        <div class="liste-offres-accueil">
                {% for offre in dernieres_offres %}
                    {# BOUM ! Même design parfait que la recherche 👇 #}
                    {% include 'offers/_card.twig' %}
                {% else %}
                    <p>Aucune offre disponible pour le moment.</p>
                {% endfor %}
            </div>
                {% else %}
                    <div class="card" style="padding: 30px; text-align: center;">
                        <p style="color: #94a3b8; font-style: italic;">Aucune offre disponible pour le moment.</p>
                    </div>
                {% endfor %}
            </div>
        </section>

        <aside class="card" style="padding: 0; overflow: hidden;">
            <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=800&q=80" alt="Conseils" style="width: 100%; height: 200px; object-fit: cover; display: block;">
            <div style="padding: 25px;">
                <h3 style="margin-bottom: 15px;">💡 Conseils CV & Entretien</h3>
                <p style="color: #94a3b8; font-size: 0.95rem; margin-bottom: 20px; line-height: 1.6;">Un bon CV fait toute la différence ! Assurez-vous de mettre en avant vos projets d'école et vos compétences techniques.</p>
                <ul style="color: #cbd5e1; font-size: 0.9rem; padding-left: 20px; margin-bottom: 20px;">
                    <li style="margin-bottom: 8px;">Restez concis (1 page max).</li>
                    <li style="margin-bottom: 8px;">Préparez vos entretiens.</li>
                    <li>Relancez après 7 jours.</li>
                </ul>
            </div>
        </aside>
    </div>
</div>
{% endblock %}  